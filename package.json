{
  "name": "breakeveninstaller",
  "version": "1.0.0",
  "main": "electron.js",
  "scripts": {
    "start": "concurrently \"react-scripts start\" \"wait-on http://localhost:3969 && node_modules\\.bin\\electron .\"",
    "build": "react-scripts build",
    "make": "electron-forge make",
    "postinstall": "echo 'Suppressing Deprecate warnings...'"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "asar": "^3.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "fs-extra": "^11.1.1",
    "unzipper": "^0.12.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "concurrently": "^8.2.0",
    "electron": "^30.5.1",
    "electron-packager": "^17.1.2",
    "eslint": "^8.57.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "wait-on": "^7.0.1"
  },
  "homepage": "./",
  "author": "thefakeliterate",
  "productName": "breakeveninstaller",
  "appId": "com.breakeventx.breakeveninstaller",
  "description": "Installer for BreakEven Client",
  "license": "thefakeliterate",
  "engines": {
    "node": ">=14.17.5"
  },
  "engineStrict": true,
  "config": {
    "forge": {
      "packagerConfig": {
        "out": "out",
        "icon": "assets/icon",
        "executableName": "breakeveninstaller",
        "prune": true,
        "asar": true,
        "ignore": [
          "(^|[\\\\/])\\.ci-assets($|[\\\\/])",
          "(^|[\\\\/])BreakEvenClient_Template\\.zip$",
          "(^|[\\\\/])BreakEvenClient_Template($|[\\\\/])",
          "^/out($|/)",
          "^/installer_dist($|/)",
          "^/\\.github($|/)",
          "^/assets($|/)"
        ],
        "asarUnpack": [
          "**/video-bg.mp4",
          "service_host/**"
        ],
        "extraResource": [
          "BreakEvenClient_Template.zip",
          "service_host"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "breakeveninstaller",
            "authors": "Breakeven LLC",
            "description": "Installer for BreakEven Client",
            "exe": "breakeveninstaller.exe",
            "setupIcon": "assets/icon.ico",
            "shortcutName": "BreakEven Installer",
            "setupExe": "BreakEven-Installer.exe",
            "processStart": "breakeveninstaller.exe"
          }
        },
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "name": "BreakEven Installer",
            "title": "BreakEven Installer",
            "format": "ULFO",
            "icon": "assets/icon.icns",
            "overwrite": true
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {
            "options": {
              "name": "breakeveninstaller",
              "productName": "BreakEven Installer",
              "genericName": "BreakEven Installer",
              "maintainer": "Breakeven LLC",
              "description": "Installer for BreakEven Client",
              "homepage": "./",
              "icon": "assets/icon.png",
              "desktopTemplate": "assets/breakeveninstaller.desktop",
              "scripts": {
                "postinst": "assets/postinst"
              }
            }
          }
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {
            "options": {
              "name": "breakeveninstaller",
              "productName": "BreakEven Installer",
              "genericName": "BreakEven Installer",
              "summary": "Installer for BreakEven Client",
              "description": "Installer for BreakEven Client",
              "homepage": "./",
              "icon": "assets/icon.png",
              "desktopTemplate": "assets/breakeveninstaller.desktop",
              "scripts": {
                "postinst": "assets/postinst"
              }
            }
          }
        }
      ],
      "files": [
        "assets/**/*",
        "icon.ico",
        "icon.png",
        "electron.js",
        "index.html",
        "terms-and-conditions.txt",
        "video-bg.mp4",
        "asset-manifest.json",
        "static/**/*",
        "package.json"
      ]
    }
  }
}
